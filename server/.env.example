# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Razorpay (secret — NEVER expose to the client)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Firebase Admin (service account). Either set the JSON path or the inline vars.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# Email (e.g. SMTP / SendGrid / Resend)
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM=no-reply@saistationary.com

# WhatsApp (e.g. Meta Cloud API / Gupshup / Twilio)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
